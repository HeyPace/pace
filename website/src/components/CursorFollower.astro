---
// Pace blue cursor that subtly follows the OS pointer with a tiny
// lag — same shape as the cursor in the actual app, same blue,
// same drop shadow. Brand continuity from website to product.
//
// Pointer-events: none so it never interferes with real clicks.
// Hidden on touch devices (no real cursor → no follower).
---

<svg class="pace-cursor-follower" viewBox="0 0 24 24" aria-hidden="true">
  <defs>
    <linearGradient id="paceFollowerGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#6b9fff" />
      <stop offset="100%" stop-color="#3a73e8" />
    </linearGradient>
  </defs>
  <path
    d="M 3 2 L 3 18 L 7 14 L 10 21 L 13 20 L 10 13 L 16 13 Z"
    fill="url(#paceFollowerGrad)"
    stroke="#ffffff"
    stroke-width="0.6"
    stroke-linejoin="round"
  />
</svg>

<script is:inline>
  (function attachPaceCursorFollower() {
    const cursorElement = document.querySelector(".pace-cursor-follower");
    if (!cursorElement) return;
    // Only show on fine-pointer devices
    if (!window.matchMedia("(pointer: fine)").matches) {
      cursorElement.style.display = "none";
      return;
    }

    let pointerX = window.innerWidth / 2;
    let pointerY = window.innerHeight / 2;
    let followerX = pointerX;
    let followerY = pointerY;
    let rafActive = false;

    function tick() {
      // Slight ease so the follower trails the real pointer — feels
      // alive rather than glued to it.
      followerX += (pointerX - followerX) * 0.18;
      followerY += (pointerY - followerY) * 0.18;
      cursorElement.style.transform = `translate(${followerX}px, ${followerY}px)`;
      const isClose = Math.hypot(pointerX - followerX, pointerY - followerY) < 0.4;
      if (isClose) {
        rafActive = false;
        return;
      }
      requestAnimationFrame(tick);
    }

    function ensureLoopRunning() {
      if (!rafActive) {
        rafActive = true;
        requestAnimationFrame(tick);
      }
    }

    window.addEventListener(
      "pointermove",
      (event) => {
        pointerX = event.clientX;
        pointerY = event.clientY;
        ensureLoopRunning();
      },
      { passive: true }
    );

    window.addEventListener("pointerleave", () => {
      cursorElement.style.opacity = "0";
    });
    window.addEventListener("pointerenter", () => {
      cursorElement.style.opacity = "1";
    });
  })();
</script>

<style>
  .pace-cursor-follower {
    position: fixed;
    top: 0;
    left: 0;
    width: 20px;
    height: 20px;
    pointer-events: none;
    z-index: 9999;
    filter: drop-shadow(0 2px 6px rgba(79, 139, 255, 0.5));
    transition: opacity 200ms ease;
    will-change: transform;
    /* Slight offset so the arrow's tip points where the OS cursor
       is, rather than the bounding-box top-left. */
    margin-left: -3px;
    margin-top: -2px;
  }

  @media (pointer: coarse) {
    .pace-cursor-follower {
      display: none;
    }
  }
</style>
